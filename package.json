{
  "name": "memory-matching-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "An interactive memory matching game built with React, TypeScript, and Tailwind CSS",
  "author": "Your Name",
  "license": "MIT",
  "keywords": [
    "react",
    "typescript",
    "game",
    "memory",
    "tailwindcss",
    "framer-motion"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules package-lock.json"
  },
  "dependencies": {
    "framer-motion": "^11.11.11",
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=22.3.0",
    "npm": ">=10.0.0"
  }
}
